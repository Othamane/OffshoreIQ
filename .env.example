# LLM Provider (Groq is free: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama3-8b-8192

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# App Settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
